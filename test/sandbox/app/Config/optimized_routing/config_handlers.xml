<?xml version="1.0" encoding="UTF-8"?>
<ae:configurations xmlns:ae="http://agavi.org/agavi/config/global/envelope/1.1" xmlns="http://agavi.org/agavi/config/parts/config_handlers/1.1" parent="%core.system_config_dir%/config_handlers.xml">
  <ae:configuration>
    <handlers>
      <handler pattern="%core.config_dir%/routing.xml" class="Agavi\Config\AgaviRoutingConfigHandler">
        <validation>%core.agavi_dir%/Config/xsd/routing.xsd</validation>
        <transformation>%core.agavi_dir%/Config/xsl/routing.xsl</transformation>
      </handler>
      <handler pattern="%core.config_dir%/output_types.xml" class="Agavi\Config\AgaviOutputTypesConfigHandler">
        <validation>%core.agavi_dir%/Config/xsd/output_types.xsd</validation>
        <transformation>%core.agavi_dir%/Config/xsl/output_types.xsl</transformation>
      </handler>
      <handler pattern="%core.config_dir%/factories.xml" class="Agavi\Config\AgaviFactoriesConfigHandler">
        <validation>%core.agavi_dir%/Config/xsd/factories.xsd</validation>
        <transformation>%core.agavi_dir%/Config/xsl/factories.xsl</transformation>
      </handler>
    </handlers>
  </ae:configuration>
</ae:configurations>
