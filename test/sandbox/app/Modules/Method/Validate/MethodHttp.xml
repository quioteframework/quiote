<?xml version="1.0" encoding="UTF-8"?>
<ae:configurations xmlns="http://agavi.org/agavi/config/parts/validators/1.1" xmlns:ae="http://agavi.org/agavi/config/global/envelope/1.1">
  <ae:configuration>
    <validators>
  <validator class="Agavi\Validator\AgaviRegexValidator" name="fail_param" required="false">
        <arguments>
          <argument>fail</argument>
        </arguments>
        <errors>
          <error>Invalid fail flag</error>
        </errors>
        <ae:parameters>
          <ae:parameter name="pattern">/^[01]$/</ae:parameter>
          <ae:parameter name="match">1</ae:parameter>
        </ae:parameters>
      </validator>
    </validators>
  </ae:configuration>
</ae:configurations>
