:80 {
	root * /app/pub
	
	# Enable FrankenPHP
	php_server
	
	# Handle clean URLs - rewrite everything to index.php unless file exists
	try_files {path} {path}/ /index.php?{query}
	
	# Enable file serving for static assets
	file_server
	
	# Add some debugging headers to see what's happening
	header {
		X-Server "FrankenPHP-Caddy"
		X-Debug-Script-Name "{http.request.uri.path}"
	}
	
	# Log requests for debugging
	log {
		output stdout
		format console
	}
}
