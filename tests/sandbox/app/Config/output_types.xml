<?xml version="1.0" encoding="UTF-8"?>
<ae:configurations xmlns:ae="http://quiote.dev/quiote/config/global/envelope/1.1" xmlns="http://quiote.dev/quiote/config/parts/output_types/1.1">

	<ae:configuration>

		<output_types default="html">

			<output_type name="html">

				<renderers default="php">
					<renderer name="php" class="Quiote\Renderer\PhpRenderer">
						<ae:parameter name="assigns">
							<ae:parameter name="routing">ro</ae:parameter>
							<ae:parameter name="request">rq</ae:parameter>
							<ae:parameter name="controller">ct</ae:parameter>
							<ae:parameter name="user">us</ae:parameter>
							<ae:parameter name="translation_manager">tm</ae:parameter>
							<ae:parameter name="request_data">rd</ae:parameter>
						</ae:parameter>
					</renderer>
				</renderers>

				<layouts default="default">
					<layout name="default">
						<layer name="content" />
					</layout>
				</layouts>

				<ae:parameter name="http_headers">
					<ae:parameter name="Content-Type">text/html; charset=UTF-8</ae:parameter>
				</ae:parameter>

			</output_type>

			<output_type name="controllerTest">
				<renderers default="php">
					<renderer name="php" class="Quiote\Renderer\PhpRenderer" />
				</renderers>
			</output_type>

			<output_type name="json">
				<renderers default="php">
					<renderer name="php" class="Quiote\Renderer\PhpRenderer" />
				</renderers>
				<ae:parameter name="http_headers">
					<ae:parameter name="Content-Type">application/json; charset=UTF-8</ae:parameter>
				</ae:parameter>
			</output_type>

			<output_type name="xml">
				<renderers default="php">
					<renderer name="php" class="Quiote\Renderer\PhpRenderer" />
				</renderers>
				<ae:parameter name="http_headers">
					<ae:parameter name="Content-Type">application/xml; charset=UTF-8</ae:parameter>
				</ae:parameter>
			</output_type>

			<!-- Added for testUnsupportedOutputTypeFallsBackToGenericExecute: no executeXls() method exists -->
			<output_type name="xls">
				<renderers default="php">
					<renderer name="php" class="Quiote\Renderer\PhpRenderer" />
				</renderers>
				<ae:parameter name="http_headers">
					<ae:parameter name="Content-Type">application/vnd.ms-excel; charset=UTF-8</ae:parameter>
				</ae:parameter>
			</output_type>


		</output_types>

	</ae:configuration>

</ae:configurations>
