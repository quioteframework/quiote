<?xml version="1.0" encoding="UTF-8"?>
<ae:configurations xmlns:ae="http://quiote.dev/quiote/config/global/envelope/1.1" xmlns="http://quiote.dev/quiote/config/parts/output_types/1.1">
  <ae:configuration>
    <output_types default="html">
      <output_type name="html">
        <renderers default="php">
          <renderer name="php" class="Quiote\Renderer\PhpRenderer" />
        </renderers>
        <layouts default="default">
          <layout name="default">
            <layer name="content" />
          </layout>
        </layouts>
      </output_type>
    </output_types>
  </ae:configuration>
</ae:configurations>
