<?php

namespace Agavi\Response;

use Agavi\Controller\AgaviOutputType;
use Agavi\Util\AgaviAttributeHolder;
use Agavi\AgaviContext;
use Symfony\Contracts\Service\ResetInterface;

class AgaviWebResponse extends AgaviAttributeHolder implements ResetInterface
{
    protected $content = null;
    protected $httpHeaders = [];
    protected $httpStatusCode = '200';

    public function initialize(AgaviContext $context, array $parameters = [])
    {
        $this->setParameters($parameters);
    }

    public function setHttpHeader($name, $value, $replace = true)
    {
        $name = $this->normalizeHttpHeaderName($name);
        if (!isset($this->httpHeaders[$name]) || $replace) $this->httpHeaders[$name] = [];
        if (is_array($value)) $this->httpHeaders[$name] = array_merge($this->httpHeaders[$name], $value);
        else $this->httpHeaders[$name][] = $value;
    }

    public function normalizeHttpHeaderName($name) { return str_replace(' ', '-', ucwords(str_replace('-', ' ', strtolower((string) $name)))); }

    public function setHttpStatusCode($code) { $this->httpStatusCode = (string)$code; }
    public function getHttpStatusCode() { return $this->httpStatusCode; }

    public function setContent($content) { $this->content = $content; }
    public function getContent() { return $this->content; }

    public function send(?AgaviOutputType $outputType = null)
    {
        foreach ($this->httpHeaders as $name => $values) {
            foreach ($values as $idx => $value) {
                header($name . ': ' . $value, $idx !== 0);
            }
        }
        if (is_resource($this->content)) { fpassthru($this->content); fclose($this->content); }
        else { echo $this->content; }
    }

    public function clear() { $this->content = null; $this->httpHeaders = []; $this->httpStatusCode = '200'; }
    public function reset(): void { $this->clear(); }
}
