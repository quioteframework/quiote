# Set this to the path to the Quiote installation's source directory. This is
# the directory that contains the `quiote.php' file.
QUIOTE_SOURCE_DIRECTORY="@PEAR-DIR@/quiote"

# Set this to the path to a PHP binary.
PHP_EXECUTABLE=$( which php )

# Message display shortcuts.
quiote_message_null()
{
	printf "\n"
}

quiote_message_notice()
{
	MESSAGE=$1
	printf "   [notice] %s\n" "${MESSAGE}"
}

quiote_message_warning()
{
	MESSAGE=$1
	printf "  [warning] %s\n" "${MESSAGE}"
}

quiote_message_error()
{
	MESSAGE=$1
	printf "    [error] %s\n" "${MESSAGE}"
}

quiote_message_fatal()
{
	MESSAGE=$1
	RETURN=$2
	printf "    [fatal] %s\n" "${MESSAGE}"
	exit $RETURN
}

quiote_input()
{
	VARIABLE=$1
	MESSAGE=$2
	PROMPT=$3
	printf "        [?] %s%s " "${MESSAGE}" "${PROMPT}"
	read "${VARIABLE}"
}

# Initial detection.
php_executable_exists()
{
	if test -x "${PHP_EXECUTABLE}"; then
		return 0
	else
		return 1
	fi
}

quiote_directory_exists()
{
	if test -d "${QUIOTE_SOURCE_DIRECTORY}" -a -e "${QUIOTE_SOURCE_DIRECTORY}/quiote.php"; then
		return 0
	else
		return 1
	fi
}

until php_executable_exists; do
	if [ -z "${PHP_EXECUTABLE}" ]; then
		PHP_EXECUTABLE="(unknown)"
	fi
	quiote_message_error "PHP not found at ${PHP_EXECUTABLE}."
	quiote_message_error "Please set the PHP_EXECUTABLE variable in the script"
	quiote_message_error "${0} to avoid this message."
	quiote_message_null
	quiote_input PHP_EXECUTABLE "Path to PHP executable" ":"
	quiote_message_null
done

until quiote_directory_exists; do
	if [ -z "${QUIOTE_SOURCE_DIRECTORY}" ]; then
		QUIOTE_SOURCE_DIRECTORY="(unknown)"
	fi
	quiote_message_error "No Quiote installation found in ${QUIOTE_SOURCE_DIRECTORY}."
	quiote_message_error "Please set the QUIOTE_SOURCE_DIRECTORY variable in the script"
	quiote_message_error "${0} to avoid this message."
	quiote_message_null
	quiote_input QUIOTE_SOURCE_DIRECTORY "Path to Quiote source directory" ":"
	quiote_message_null
done

# Call build script.
`which rlwrap` ${PHP_EXECUTABLE} -d memory_limit=4294967295 -f "${QUIOTE_SOURCE_DIRECTORY}/build/quiote/script/quiote.php" -- --quiote-source-directory "${QUIOTE_SOURCE_DIRECTORY}" "$@"

