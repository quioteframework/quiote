<?xml version="1.0" encoding="UTF-8"?>
<ae:configurations xmlns:ae="http://quiote.dev/quiote/config/global/envelope/1.1" xmlns="http://quiote.dev/quiote/config/parts/config_handlers/1.1">
	<ae:configuration>
		<handlers>
			<!--
				+~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~+
				| Core Quiote configuration handlers.                                         |
				+~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~+
			-->


			<handler pattern="%core.config_dir%/settings.xml" class="Quiote\Config\SettingConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/settings.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/settings.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/factories.xml" class="Quiote\Config\FactoryConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/factories.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/factories.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/databases.xml" class="Quiote\Config\DatabaseConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/databases.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/databases.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/output_types.xml" class="Quiote\Config\OutputTypeConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/output_types.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/output_types.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/rbac_definitions.xml" class="Quiote\Config\RbacDefinitionConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/rbac_definitions.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/rbac_definitions.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/routing.xml" class="Quiote\Config\RoutingConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/routing.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/routing.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/translation.xml" class="Quiote\Config\TranslationConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/translation.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/translation.xsl</transformation>
			</handler>

			<handler pattern="%core.config_dir%/plugins.xml" class="Quiote\Config\PluginConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/plugins.xsd</validation>
			</handler>

			<handler pattern="%core.config_dir%/middleware.xml" class="Quiote\Config\MiddlewareConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/middleware.xsd</validation>
			</handler>
		<handler pattern="%core.testing_dir%/Config/suites.xml" class="Quiote\Config\TestSuitesConfigHandler">
			<!-- <validation>%core.quiote_dir%/Config/xsd/module.xsd</validation>-->
			<transformation>%core.quiote_dir%/Config/xsl/testing.suites.xsl</transformation>
		</handler>

			<!--
				+~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~+
				| Global Quiote configuration handlers.                                       |
				| ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ |
				| These handlers must not be registered with a relative path, because they   |
				| need to be associated with module configuration files of the same base     |
				| name. DO NOT register relative path configuration files with these base    |
				| names or the system may cease to function.                                 |
				+~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~+
			-->

			<handler pattern="%core.module_dir%/*/Config/module.xml" class="Quiote\Config\ModuleConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/module.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/module.xsl</transformation>
			</handler>

			<handler pattern="%core.module_dir%/*/Validate/*.xml" class="Quiote\Config\ValidatorConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/validators.xsd</validation>
				<transformation>%core.quiote_dir%/Config/xsl/validators.xsl</transformation>
			</handler>

			<!--
				Drop-in module contributions: a module directory (whether shipped
				with the app or dropped in by a third party) can register its own
				plugins and/or middleware just by containing these files, no app
				wiring required. See Quiote::bootstrap()'s module-config glob and
				Quiote\Middleware\Config\MiddlewareConfigRegistry.
			-->
			<handler pattern="%core.module_dir%/*/Config/plugins.xml" class="Quiote\Config\PluginConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/plugins.xsd</validation>
			</handler>

			<handler pattern="%core.module_dir%/*/Config/middleware.xml" class="Quiote\Config\MiddlewareConfigHandler">
				<validation>%core.quiote_dir%/Config/xsd/middleware.xsd</validation>
			</handler>
		</handlers>
	</ae:configuration>
</ae:configurations>