<?xml version="1.0" encoding="UTF-8"?>
<phpunit
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         executionOrder="depends,defects"
         requireCoverageMetadata="false"
         beStrictAboutCoverageMetadata="false"
         beStrictAboutOutputDuringTests="true"
         failOnRisky="false"
         failOnWarning="false">
    <testsuites>
        <testsuite name="unit">
            <directory>tests/tests/unit</directory>
            <!-- The subsystems below now live in packages/*; still run from the root suite while
                 everything shares one composer install (via the packages/* path
                 repository). Once each package gets its own isolated CI job, its line
                 moves to that package's own phpunit config. Docker-based integration
                 tests under packages/db-*/tests are #[Group('integration')]-tagged, so
                 the <groups><exclude> below still keeps them out of a plain `composer
                 test` run; `composer test:integration` runs them explicitly. -->
            <directory>packages/mcp/tests</directory>
            <directory>packages/ratelimit/tests</directory>
            <directory>packages/csrf/tests</directory>
            <directory>packages/whoops/tests</directory>
            <directory>packages/db-eloquent/tests</directory>
            <directory>packages/db-doctrine/tests</directory>
            <directory>packages/db-cycle/tests</directory>
            <directory>packages/db-propulsion/tests</directory>
            <directory>packages/telemetry-otel/tests</directory>
            <directory>packages/telemetry-dashboard/tests</directory>
            <directory>packages/phptal/tests</directory>
            <directory>packages/xslt/tests</directory>
            <directory>packages/twig/tests</directory>
            <directory>packages/session-pdo/tests</directory>
            <directory>packages/session-azure/tests</directory>
            <directory>packages/session-s3/tests</directory>
            <directory>packages/session-gcs/tests</directory>
        </testsuite>
        <testsuite name="flow">
            <directory>tests/tests/flow</directory>
        </testsuite>
        <testsuite name="fragment">
            <directory>tests/tests/fragment</directory>
        </testsuite>
        <testsuite name="psr">
            <directory>tests/PsrPipeline</directory>
        </testsuite>
    </testsuites>
    <!--
        APCu is disabled by default for the test run. The APCu config cache is
        backed by a process-wide store that is not reset between tests and can
        leak compiled config between unrelated test classes. The tests covering
        QuioteAPCuConfigCache are tagged @group apcu and excluded here; run them
        explicitly with `composer test:apcu` (which enables apc.enable_cli).

        e2e tests spin up real Docker containers (an OTel Collector plus a
        FrankenPHP-served build of samples/app; see tests/e2e/). They live
        outside every directory listed under <testsuites> above, so they are
        never discovered by a plain `vendor/bin/phpunit` run regardless of
        this exclusion; the #[Group('e2e')] tag is a second, belt-and-braces
        safety net (and lets tooling that filters by group find them). Run
        them explicitly with `composer test:e2e`.
    -->
    <groups>
        <exclude>
            <group>apcu</group>
            <group>e2e</group>
            <group>integration</group>
        </exclude>
    </groups>
    <php>
        <env name="QUIOTE_ISOLATION_ENVIRONMENT" value="testing"/>
        <env name="QUIOTE_ISOLATION_DEFAULT_CONTEXT" value="web"/>
        <env name="QUIOTE_ISOLATION_CLEAR_CACHE" value="1"/>
           <ini name="display_errors" value="On" />
        <ini name="display_startup_errors" value="On" />
    </php>
    <source>
        <include>
            <directory>Quiote</directory>
            <directory>packages/mcp/src</directory>
            <directory>packages/ratelimit/src</directory>
            <directory>packages/csrf/src</directory>
            <directory>packages/whoops/src</directory>
            <directory>packages/db-eloquent/src</directory>
            <directory>packages/db-doctrine/src</directory>
            <directory>packages/db-cycle/src</directory>
            <directory>packages/db-propulsion/src</directory>
            <directory>packages/telemetry-otel/src</directory>
            <directory>packages/telemetry-dashboard/src</directory>
            <directory>packages/phptal/src</directory>
            <directory>packages/xslt/src</directory>
            <directory>packages/twig/src</directory>
            <directory>packages/session-pdo/src</directory>
            <directory>packages/session-azure/src</directory>
            <directory>packages/session-s3/src</directory>
            <directory>packages/session-gcs/src</directory>
        </include>
        <exclude>
        <directory>Quiote/translation/data</directory>
        </exclude>
    </source>
    <coverage>
        <report>
            <html outputDirectory="coverage/html"/>
            <clover outputFile="coverage/clover.xml"/>
            <text outputFile="php://stdout" showUncoveredFiles="false"/>
        </report>
    </coverage>
</phpunit>
